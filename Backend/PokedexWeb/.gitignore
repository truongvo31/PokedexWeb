## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# Build results
[Dd]ebug/
[Rr]elease/
x64/
x86/
build/
bld/
[Bb]in/
[Oo]bj/

# Visual Studio
.vs/

# MonoDevelop
*.pidb
*.userprefs

# Rider
.idea/

# ReSharper
_ReSharper*/
*.DotSettings.user

# NuGet
*.nupkg
*.snupkg
packages/
.nuget/

# .NET Core
project.lock.json
project.fragment.lock.json
artifacts/

# ASP.NET Scaffolding
ScaffoldingReadMe.txt

# Logs
*.log

# Test results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# Coverage
*.coverage
*.coveragexml

# OS files
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# Windows Installer files
*.cab
*.msi
*.msix
*.msm
*.msp

# Visual Studio cache/options directory
.vscode/

# Publish output
*.Publish.xml
*.pubxml
*.publishproj

# Azure
csx/
*.build.csdef

# SQL Server
*.mdf
*.ldf

# IIS Express
IISExpress/
